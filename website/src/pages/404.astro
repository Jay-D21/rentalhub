---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="404 — Page Not Found · RentalHub"
  description="The page you're looking for doesn't exist. Let's get you back on track."
>

<div class="error-page">
  <div class="container" style="text-align:center;">
    <div class="error-code" data-reveal>404</div>
    <h1 class="error-title" data-reveal data-delay="100">Page Not Found</h1>
    <p class="error-desc" data-reveal data-delay="200">
      Looks like this road doesn't exist. The page you're looking for may have been moved or deleted.
    </p>
    <div class="error-actions" data-reveal data-delay="300">
      <a href="/" class="btn btn-primary btn-lg">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        Go Home
      </a>
      <a href="/contact" class="btn btn-secondary btn-lg">Contact Support</a>
    </div>

    <!-- Quick links -->
    <div style="margin-top:var(--space-3xl);" data-reveal data-delay="400">
      <p style="color:var(--text-muted); font-size:0.875rem; margin-bottom:var(--space-lg);">Or visit one of these pages:</p>
      <div style="display:flex; gap:var(--space-md); justify-content:center; flex-wrap:wrap;">
        <a href="/pricing" class="btn btn-secondary btn-sm">Pricing</a>
        <a href="/faq" class="btn btn-secondary btn-sm">FAQ</a>
        <a href="/register" class="btn btn-secondary btn-sm">Register Shop</a>
        <a href="/about" class="btn btn-secondary btn-sm">About</a>
      </div>
    </div>
  </div>
</div>

</BaseLayout>
