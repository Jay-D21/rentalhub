---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="500 — Server Error · RentalHub"
  description="Something went wrong on our end. We're working on it."
>

<div class="error-page">
  <div class="container" style="text-align:center;">
    <div class="error-code" style="color:var(--brand-red);" data-reveal>500</div>
    <h1 class="error-title" data-reveal data-delay="100">Something Went Wrong</h1>
    <p class="error-desc" data-reveal data-delay="200">
      Our servers hit a speed bump. Don't worry — our team has been notified and we're fixing it as fast as we can.
    </p>
    <div class="error-actions" data-reveal data-delay="300">
      <a href="/" class="btn btn-primary btn-lg">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        Go Home
      </a>
      <a href="/contact" class="btn btn-secondary btn-lg">Report Issue</a>
    </div>
    <p style="color:var(--text-muted); font-size:0.8rem; margin-top:var(--space-2xl);" data-reveal data-delay="400">
      If this keeps happening, please email us at <a href="mailto:contact@rentalhub.in" style="color:var(--accent)">contact@rentalhub.in</a>
    </p>
  </div>
</div>

</BaseLayout>
