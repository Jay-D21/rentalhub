---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../data/site.json';
import hero from '../data/hero.json';
import stats from '../data/stats.json';
import vehicles from '../data/vehicles.json';
import howItWorks from '../data/howItWorks.json';
import pricing from '../data/pricing.json';
import testimonials from '../data/testimonials.json';
import cities from '../data/cities.json';
import faq from '../data/faq.json';

const previewFaq = faq.categories[0].items.slice(0, 4);
const activeCities = cities.cities.filter(c => c.active);
const comingSoon = cities.cities.filter(c => !c.active);
---

<BaseLayout
  title={`${site.brand.name} — Rent Bikes & Cars from Trusted Shops Near You`}
  description="India's fastest-growing vehicle rental marketplace. Find verified bike and car rental shops near you. 8% commission, no lock-in. 500+ partners across India."
>

<!-- ===== HERO ===== -->
<section class="hero" id="hero">
  <div class="container">
    <div class="hero-inner">
      <div class="hero-badge" data-reveal>
        <span class="pulse-dot"></span>
        {hero.badge}
      </div>

      <h1 class="hero-title" data-reveal data-delay="100">
        {hero.headline}
      </h1>

      <p class="hero-sub" data-reveal data-delay="200">
        {hero.subheadline}
      </p>

      <!-- Search Bar -->
      <div class="search-bar" data-reveal data-delay="300">
        <div class="search-field">
          <label for="searchCity">City</label>
          <select id="searchCity" class="search-select" aria-label="Select city">
            <option value="">Select your city...</option>
            {cities.cities.filter(c => c.active).map(c => (
              <option value={c.name.toLowerCase()}>{c.name}</option>
            ))}
          </select>
        </div>
        <div class="search-field">
          <label for="searchVehicle">Vehicle Type</label>
          <select id="searchVehicle" aria-label="Select vehicle type">
            <option value="">All vehicles</option>
            <option value="bike">Bikes</option>
            <option value="scooter">Scooters</option>
            <option value="car">Cars</option>
          </select>
        </div>
        <div class="search-field">
          <label for="searchDate">From Date</label>
          <input type="date" id="searchDate" aria-label="Select start date" />
        </div>
        <button class="search-btn" id="searchBtn" type="button" aria-label="Search vehicles">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          Search
        </button>
      </div>

      <!-- Hero CTAs -->
      <div class="hero-ctas" data-reveal data-delay="400">
        <a href="#vehicles" class="btn btn-primary btn-lg">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          Browse Vehicles
        </a>
        <a href="/register" class="btn btn-secondary btn-lg">
          Register Your Shop →
        </a>
      </div>

      <!-- Stats -->
      <div class="hero-stats" data-reveal data-delay="500">
        {stats.counters.map(stat => (
          <div class="hstat">
            <div class="hstat-num" data-count={stat.isDecimal ? undefined : stat.value} data-suffix={stat.suffix} data-decimal={stat.isDecimal ? stat.value : undefined}>
              {stat.isDecimal ? `${stat.value}${stat.suffix}` : `0${stat.suffix}`}
            </div>
            <div class="hstat-lbl">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- ===== VEHICLE LISTINGS ===== -->
<section class="section" id="vehicles" style="background: var(--bg-secondary);">
  <div class="container">
    <div class="section-header" data-reveal>
      <div class="section-label">Available Now</div>
      <h2>Bikes, Scooters & Cars Near You</h2>
      <p>Browse verified vehicles from trusted rental shops. All listings include transparent pricing, real reviews, and insurance coverage.</p>
    </div>

    <!-- Type filter tabs -->
    <div class="vehicles-tabs" data-reveal>
      {vehicles.types.map((type, i) => (
        <button class={`vtab ${i === 0 ? 'active' : ''}`} data-type={type.toLowerCase()} type="button">
          {type}
        </button>
      ))}
    </div>

    <!-- Vehicle Grid -->
    <div class="vehicle-grid" id="vehicleGrid" data-reveal data-delay="100">
      {vehicles.vehicles.map(v => (
        <article class="vehicle-card" data-vehicle-type={v.type}>
          <div class="vehicle-img">
            <!-- SVG Placeholder by type -->
            {v.type === 'bike' && (
              <svg viewBox="0 0 200 120" fill="none" xmlns="http://www.w3.org/2000/svg">
                <ellipse cx="55" cy="85" rx="28" ry="28" stroke="var(--accent)" stroke-width="5" fill="none"/>
                <ellipse cx="145" cy="85" rx="28" ry="28" stroke="var(--accent)" stroke-width="5" fill="none"/>
                <path d="M55 85 L85 45 L120 45 L145 85" stroke="var(--text-muted)" stroke-width="5" stroke-linecap="round"/>
                <path d="M100 45 L110 25 L130 25" stroke="var(--text-muted)" stroke-width="4" stroke-linecap="round"/>
                <path d="M85 45 L100 45" stroke="var(--text-muted)" stroke-width="4" stroke-linecap="round"/>
                <circle cx="110" cy="24" r="6" fill="var(--accent)" opacity="0.6"/>
              </svg>
            )}
            {v.type === 'scooter' && (
              <svg viewBox="0 0 200 120" fill="none" xmlns="http://www.w3.org/2000/svg">
                <ellipse cx="50" cy="88" rx="24" ry="24" stroke="var(--accent)" stroke-width="5" fill="none"/>
                <ellipse cx="150" cy="88" rx="24" ry="24" stroke="var(--accent)" stroke-width="5" fill="none"/>
                <path d="M50 88 C50 60 80 50 100 50 L130 50 L150 88" stroke="var(--text-muted)" stroke-width="5" stroke-linecap="round" fill="none"/>
                <path d="M100 50 L100 35 C100 30 110 28 115 30 L130 35" stroke="var(--text-muted)" stroke-width="4" stroke-linecap="round"/>
                <rect x="68" y="52" width="52" height="20" rx="10" fill="var(--accent)" opacity="0.25"/>
              </svg>
            )}
            {v.type === 'car' && (
              <svg viewBox="0 0 200 120" fill="none" xmlns="http://www.w3.org/2000/svg">
                <ellipse cx="55" cy="90" rx="22" ry="22" stroke="var(--accent)" stroke-width="5" fill="none"/>
                <ellipse cx="145" cy="90" rx="22" ry="22" stroke="var(--accent)" stroke-width="5" fill="none"/>
                <path d="M20 80 L33 55 C40 45 60 40 100 40 C140 40 160 45 167 55 L180 80 L180 90 L20 90 Z" stroke="var(--text-muted)" stroke-width="4" fill="var(--accent)" opacity="0.1"/>
                <rect x="45" y="48" width="110" height="32" rx="4" fill="var(--accent)" opacity="0.15"/>
                <line x1="100" y1="48" x2="100" y2="80" stroke="var(--text-muted)" stroke-width="2"/>
              </svg>
            )}
            <div class="vehicle-badge">
              {v.available
                ? <span class="badge badge-green">Available</span>
                : <span class="badge badge-gray">Available {v.availableFrom}</span>
              }
            </div>
          </div>
          <div class="vehicle-body">
            <div class="vehicle-meta">
              <span class="vehicle-location">📍 {v.location}</span>
              <span class="vehicle-rating">★ {v.rating} <em>({v.reviews})</em></span>
            </div>
            <h3 class="vehicle-name">{v.name}</h3>
            <div class="vehicle-price">
              ₹{v.priceDay.toLocaleString('en-IN')}<span>/day</span>
            </div>
            <div class="vehicle-features">
              {v.features.map(f => <span class="vehicle-feature">{f}</span>)}
            </div>
            {v.available
              ? <a href="/register" class="btn btn-primary btn-full">Book Now</a>
              : <button class="btn btn-secondary btn-full" disabled>Available {v.availableFrom}</button>
            }
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- ===== HOW IT WORKS ===== -->
<section class="section" id="how-it-works">
  <div class="container">
    <div class="section-header centered" data-reveal>
      <div class="section-label">Simple Process</div>
      <h2>How RentalHub Works</h2>
      <p>From search to ride in minutes. No paperwork, no hassle, no hidden fees.</p>
    </div>
    <div class="steps-grid">
      {howItWorks.steps.map((step, i) => (
        <div class="step" data-reveal data-delay={`${i * 100}`}>
          <div class="step-icon">
            {step.icon === 'search' && <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>}
            {step.icon === 'calendar' && <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>}
            {step.icon === 'key' && <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>}
          </div>
          <div class="step-number">{step.number}</div>
          <h3>{step.title}</h3>
          <p>{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ===== WHY RENTALHUB ===== -->
<section class="section" style="background: var(--bg-secondary);">
  <div class="container">
    <div class="section-header" data-reveal>
      <div class="section-label">Our Advantage</div>
      <h2>Why Rental Shops Choose RentalHub</h2>
      <p>We built the platform we wished existed — fair commission, no lock-in, real technology.</p>
    </div>
    <div class="usp-grid" data-reveal>
      <div class="usp-card">
        <div class="usp-icon" style="background: rgba(255,59,59,0.1); color: var(--brand-red);">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
        </div>
        <h3>Only 8% Commission</h3>
        <p>Competitors charge 25–35%. We charge 8% — that's 3x more money in your pocket on every booking. On a ₹1,000 rental, you keep ₹920.</p>
      </div>
      <div class="usp-card">
        <div class="usp-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg>
        </div>
        <h3>No Exclusivity Contracts</h3>
        <p>List on RentalHub alongside any other platform. No lock-in, no penalties, no minimum bookings. You stay in full control of your business.</p>
      </div>
      <div class="usp-card">
        <div class="usp-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
        </div>
        <h3>Real-Time Dashboard</h3>
        <p>Manage your entire fleet from your phone. Live booking notifications, availability calendar, customer communications, and revenue analytics — all in one place.</p>
      </div>
      <div class="usp-card">
        <div class="usp-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <h3>Pan-India Network</h3>
        <p>Already live in Pune, Mumbai, Bangalore, Hyderabad, Delhi, and Goa. Expanding to 50+ cities in 2026. Your shop gets visibility across India.</p>
      </div>
    </div>
  </div>
</section>

<!-- ===== PARTNER CTA ===== -->
<section class="section" id="partner">
  <div class="container">
    <div class="partner-cta" data-reveal>
      <div>
        <div class="section-label" style="color: rgba(255,255,255,0.6);">For Rental Shop Owners</div>
        <h2 style="color:#fff; margin-bottom: var(--space-md);">{hero.partnerSection.headline}</h2>
        <p style="color: rgba(236,239,241,0.75); font-size: 1.05rem;">{hero.partnerSection.subheadline}</p>
        <ul class="partner-points">
          {hero.partnerSection.points.map(point => (
            <li class="partner-point">{point}</li>
          ))}
        </ul>
        <a href={hero.partnerSection.cta.href} class="btn btn-lg" style="background:#0066FF; color:#fff; border-color:#0066FF;">
          {hero.partnerSection.cta.text} →
        </a>
      </div>
      <div>
        <!-- Commission highlight card -->
        <div style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: var(--radius-xl); padding: var(--space-2xl); text-align: center;">
          <p style="color: rgba(255,255,255,0.6); font-size: 0.875rem; margin-bottom: var(--space-md);">PLATFORM COMMISSION</p>
          <div style="font-family: 'Space Grotesk', sans-serif; font-size: 5rem; font-weight: 700; color: #FF3B3B; line-height: 1;">8%</div>
          <p style="color: rgba(255,255,255,0.5); font-size: 0.875rem; margin-bottom: var(--space-xl);">per booking · all plans</p>
          <div style="background: rgba(255,255,255,0.06); border-radius: var(--radius-md); padding: var(--space-md);">
            <p style="color: rgba(255,255,255,0.4); font-size: 0.8rem; margin-bottom: 0.5rem;">vs competitors</p>
            <div style="font-family: 'Space Grotesk', sans-serif; font-size: 1.8rem; font-weight: 700; color: rgba(255,255,255,0.25); text-decoration: line-through;">25–35%</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ===== CITY COVERAGE ===== -->
<section class="section" style="background: var(--bg-secondary);" id="cities">
  <div class="container">
    <div class="section-header centered" data-reveal>
      <div class="section-label">Pan-India</div>
      <h2>Available Across India</h2>
      <p>From metro cities to tourist destinations. Find trusted rental shops wherever you are.</p>
    </div>
    <div class="cities-grid" data-reveal>
      {activeCities.map(city => (
        <div class="city-card active">
          <div class="city-name">{city.name}</div>
          <div class="city-state">{city.state}</div>
          <div class="city-partners">{city.partners}+ Partners</div>
        </div>
      ))}
      {comingSoon.map(city => (
        <div class="city-card" style="opacity: 0.5;">
          <div class="city-name">{city.name}</div>
          <div class="city-state">{city.state}</div>
          <span class="badge badge-gray" style="margin-top: 0.5rem; font-size: 0.68rem;">Coming Soon</span>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ===== TESTIMONIALS ===== -->
<section class="section" id="testimonials">
  <div class="container">
    <div class="section-header centered" data-reveal>
      <div class="section-label">Stories</div>
      <h2>What Our Partners & Riders Say</h2>
      <p>Real experiences from rental shop owners and customers across India.</p>
    </div>
    <div class="testimonial-slider" data-reveal>
      <div class="testimonial-track" id="testimonialTrack">
        {testimonials.testimonials.map(t => (
          <div class="testimonial-card">
            <p class="testimonial-quote">"{t.quote}"</p>
            <div class="testimonial-author">
              <div class="testimonial-avatar">{t.avatar}</div>
              <div>
                <div class="testimonial-name">{t.name}</div>
                <div class="testimonial-role">{t.role} · {t.city}</div>
                <div class="testimonial-type-badge">
                  {t.type === 'partner'
                    ? <span class="badge badge-blue">Rental Partner</span>
                    : <span class="badge badge-green">Verified Rider</span>
                  }
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
      <div class="slider-controls">
        <button class="slider-btn" id="sliderPrev" aria-label="Previous testimonial">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <div class="slider-dots" id="sliderDots">
          {testimonials.testimonials.map((_, i) => (
            <button class={`slider-dot ${i === 0 ? 'active' : ''}`} data-idx={i} aria-label={`Go to testimonial ${i+1}`}></button>
          ))}
        </div>
        <button class="slider-btn" id="sliderNext" aria-label="Next testimonial">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      </div>
    </div>
  </div>
</section>

<!-- ===== FAQ PREVIEW ===== -->
<section class="section" style="background: var(--bg-secondary);" id="faq-preview">
  <div class="container">
    <div style="display:flex; justify-content:space-between; align-items:flex-end; flex-wrap:wrap; gap:var(--space-md); margin-bottom:var(--space-2xl);" data-reveal>
      <div class="section-header" style="margin-bottom:0">
        <div class="section-label">FAQ</div>
        <h2>Frequently Asked Questions</h2>
      </div>
      <a href="/faq" class="btn btn-secondary">View All FAQs →</a>
    </div>
    <div class="accordion" data-reveal>
      {previewFaq.map((item, i) => (
        <div class="accordion-item" id={`faq-${i}`}>
          <button class="accordion-header" aria-expanded="false" aria-controls={`faq-body-${i}`}>
            <span class="accordion-question">{item.q}</span>
            <span class="accordion-icon" aria-hidden="true">+</span>
          </button>
          <div class="accordion-body" id={`faq-body-${i}`} role="region">
            <p class="accordion-answer">{item.a}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ===== CTA BANNER ===== -->
<section class="section">
  <div class="container">
    <div class="cta-banner" data-reveal>
      <h2>Ready to Grow Your Rental Business?</h2>
      <p>Join 500+ rental shops already on RentalHub. Sign up in 10 minutes. Start getting bookings today.</p>
      <div style="display:flex; gap:var(--space-md); justify-content:center; flex-wrap:wrap;">
        <a href="/register" class="btn btn-lg" style="background:#fff; color: #191970;">Register Your Shop — Free</a>
        <a href="/pricing" class="btn btn-lg btn-secondary" style="border-color:rgba(255,255,255,0.3); color:#fff;">View Pricing →</a>
      </div>
    </div>
  </div>
</section>

</BaseLayout>

<script>
  // ── Vehicle type filter ──
  const vtabs = document.querySelectorAll('.vtab');
  const cards = document.querySelectorAll('.vehicle-card') as NodeListOf<HTMLElement>;
  vtabs.forEach(tab => {
    tab.addEventListener('click', () => {
      vtabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      const type = (tab as HTMLElement).dataset.type;
      cards.forEach(card => {
        if (type === 'all' || card.dataset.vehicleType === type.slice(0,-1) || card.dataset.vehicleType === type) {
          card.style.display = '';
        } else {
          card.style.display = 'none';
        }
      });
    });
  });

  // Fix type mapping for plural tabs
  document.querySelectorAll('.vtab').forEach(tab => {
    tab.addEventListener('click', () => {
      const type = (tab as HTMLElement).dataset.type!;
      cards.forEach(card => {
        const vType = card.dataset.vehicleType!;
        const show = type === 'all'
          || (type === 'bikes' && vType === 'bike')
          || (type === 'scooters' && vType === 'scooter')
          || (type === 'cars' && vType === 'car');
        (card as HTMLElement).style.display = show ? '' : 'none';
      });
    });
  });

  // ── Animated counters ──
  document.querySelectorAll('[data-count]').forEach(el => {
    const target = parseInt((el as HTMLElement).dataset.count!);
    const suffix = (el as HTMLElement).dataset.suffix || '';
    const observer = new IntersectionObserver(entries => {
      if (entries[0].isIntersecting) {
        let start = 0;
        const duration = 1500;
        const step = target / (duration / 16);
        const timer = setInterval(() => {
          start = Math.min(start + step, target);
          el.textContent = Math.floor(start).toLocaleString('en-IN') + suffix;
          if (start >= target) clearInterval(timer);
        }, 16);
        observer.unobserve(el);
      }
    }, { threshold: 0.5 });
    observer.observe(el);
  });

  // ── Testimonial slider ──
  const track = document.getElementById('testimonialTrack');
  const dots = document.querySelectorAll('.slider-dot');
  let current = 0;
  const total = dots.length;

  function getSlideWidth() {
    const w = window.innerWidth;
    if (w > 1024) return 33.333;
    if (w > 640) return 50;
    return 100;
  }

  function goTo(idx: number) {
    current = (idx + total) % total;
    const pct = getSlideWidth();
    if (track) track.style.transform = `translateX(-${current * pct}%)`;
    dots.forEach((d, i) => d.classList.toggle('active', i === current));
  }

  document.getElementById('sliderNext')?.addEventListener('click', () => goTo(current + 1));
  document.getElementById('sliderPrev')?.addEventListener('click', () => goTo(current - 1));
  dots.forEach((d, i) => d.addEventListener('click', () => goTo(i)));
  // Auto-rotate
  setInterval(() => goTo(current + 1), 5000);

  // ── Accordion ──
  document.querySelectorAll('.accordion-header').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.accordion-item')!;
      const isOpen = item.classList.contains('open');
      // Close all
      document.querySelectorAll('.accordion-item').forEach(i => i.classList.remove('open'));
      document.querySelectorAll('.accordion-header').forEach(b => b.setAttribute('aria-expanded', 'false'));
      // Open clicked if was closed
      if (!isOpen) {
        item.classList.add('open');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });

  // ── Search ──
  document.getElementById('searchBtn')?.addEventListener('click', () => {
    const city = (document.getElementById('searchCity') as HTMLSelectElement).value;
    const type = (document.getElementById('searchVehicle') as HTMLSelectElement).value;
    if (!city) {
      (window as any).showToast?.('Please select a city to search', 'error');
      return;
    }
    // Filter vehicles by city (approximate match) and type
    const cards2 = document.querySelectorAll('.vehicle-card') as NodeListOf<HTMLElement>;
    cards2.forEach(card => {
      const matchType = !type || card.dataset.vehicleType === type;
      card.style.display = matchType ? '' : 'none';
    });
    document.getElementById('vehicles')?.scrollIntoView({ behavior: 'smooth' });
    (window as any).showToast?.(`Showing ${type || 'all vehicles'} in ${city.charAt(0).toUpperCase() + city.slice(1)}`);
  });
</script>
